# Nice PlayLand - Production Configuration
# Copy ini file ke .env dan sesuaikan nilainya

# ================= APP SETTINGS =================
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-in-production

# ================= DATABASE =================
DATABASE_URL=sqlite:///database.db

# ================= MIDTRANS (Payment) =================
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ================= TICKET =================
TICKET_PRICE=35000

# ================= OFFICE LOCATION (Nice PlayLand - Indramayu) =================
OFFICE_LAT=-6.5408
OFFICE_LNG=108.4377
OFFICE_RADIUS_METERS=200

# ================= PARK INFO =================
PARK_PHONE=+62821-9999-0000
PARK_WA=+62821-9999-0000
PARK_EMAIL=info@niceplayland.com
PARK_INSTAGRAM=@niceplayland_id
PARK_FACEBOOK=NicePlayLandIndramayu

# ================= URL =================
BASE_URL=https://niceplayland.com